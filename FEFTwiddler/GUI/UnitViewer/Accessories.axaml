<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEFTwiddler.GUI.UnitViewer.Accessories">
    <WrapPanel>
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,8,4" VerticalAlignment="Center">
            <TextBlock Text="Headwear:" VerticalAlignment="Center" Width="100" />
            <ComboBox x:Name="cmbHeadwear" Width="160" DisplayMemberBinding="{Binding DisplayName}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,8,4" VerticalAlignment="Center">
            <TextBlock Text="Facewear:" VerticalAlignment="Center" Width="100" />
            <ComboBox x:Name="cmbFacewear" Width="160" DisplayMemberBinding="{Binding DisplayName}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,8,4" VerticalAlignment="Center">
            <TextBlock Text="Armwear:" VerticalAlignment="Center" Width="100" />
            <ComboBox x:Name="cmbArmwear" Width="160" DisplayMemberBinding="{Binding DisplayName}" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,8,4" VerticalAlignment="Center">
            <TextBlock Text="Underwear:" VerticalAlignment="Center" Width="100" />
            <ComboBox x:Name="cmbUnderwear" Width="160" DisplayMemberBinding="{Binding DisplayName}" />
        </StackPanel>
    </WrapPanel>
</UserControl>
