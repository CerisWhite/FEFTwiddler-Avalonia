<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEFTwiddler.GUI.UnitViewer.HairColor">
    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="Hair Color:" VerticalAlignment="Center" />
        <Border x:Name="HairColorBox" Width="24" Height="24" BorderThickness="1" BorderBrush="Gray" Background="White" />
        <TextBox x:Name="HairColorHex" Width="80" MaxLength="6" />
        <Button x:Name="btnPickColor" Content="Pick..." Click="BtnPickColor_Click" />
    </StackPanel>
</UserControl>
