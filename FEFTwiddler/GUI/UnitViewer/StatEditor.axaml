<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEFTwiddler.GUI.UnitViewer.StatEditor"
        Width="550" Height="420"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="*,Auto" Margin="12">
        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="8">
                <!-- Stat columns header -->
                <Grid ColumnDefinitions="80,90,60,60,60">
                    <TextBlock Grid.Column="0" Text="Stat" FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Text="Value" FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Text="Tonic" FontWeight="Bold" />
                    <TextBlock Grid.Column="3" Text="Status" FontWeight="Bold" />
                    <TextBlock Grid.Column="4" Text="Meal" FontWeight="Bold" />
                </Grid>
                <!-- HP row -->
                <Grid ColumnDefinitions="80,90,60,60,60">
                    <TextBlock Grid.Column="0" x:Name="lblHP" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" x:Name="numHP" Minimum="0" Maximum="99" Width="110" />
                    <CheckBox Grid.Column="2" x:Name="chkHPTonic" />
                    <!-- No status for HP -->
                    <!-- No meal for HP -->
                </Grid>
                <!-- Str row -->
                <Grid ColumnDefinitions="80,90,60,60,60">
                    <TextBlock Grid.Column="0" x:Name="lblStr" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" x:Name="numStr" Minimum="0" Maximum="99" Width="110" />
                    <CheckBox Grid.Column="2" x:Name="chkStrTonic" />
                    <CheckBox Grid.Column="3" x:Name="chkStrStatus" />
                    <CheckBox Grid.Column="4" x:Name="chkStrMeal" />
                </Grid>
                <!-- Mag row -->
                <Grid ColumnDefinitions="80,90,60,60,60">
                    <TextBlock Grid.Column="0" x:Name="lblMag" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" x:Name="numMag" Minimum="0" Maximum="99" Width="110" />
                    <CheckBox Grid.Column="2" x:Name="chkMagTonic" />
                    <CheckBox Grid.Column="3" x:Name="chkMagStatus" />
                    <CheckBox Grid.Column="4" x:Name="chkMagMeal" />
                </Grid>
                <!-- Skl row -->
                <Grid ColumnDefinitions="80,90,60,60,60">
                    <TextBlock Grid.Column="0" x:Name="lblSkl" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" x:Name="numSkl" Minimum="0" Maximum="99" Width="110" />
                    <CheckBox Grid.Column="2" x:Name="chkSklTonic" />
                    <CheckBox Grid.Column="3" x:Name="chkSklStatus" />
                    <CheckBox Grid.Column="4" x:Name="chkSklMeal" />
                </Grid>
                <!-- Spd row -->
                <Grid ColumnDefinitions="80,90,60,60,60">
                    <TextBlock Grid.Column="0" x:Name="lblSpd" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" x:Name="numSpd" Minimum="0" Maximum="99" Width="110" />
                    <CheckBox Grid.Column="2" x:Name="chkSpdTonic" />
                    <CheckBox Grid.Column="3" x:Name="chkSpdStatus" />
                    <CheckBox Grid.Column="4" x:Name="chkSpdMeal" />
                </Grid>
                <!-- Lck row -->
                <Grid ColumnDefinitions="80,90,60,60,60">
                    <TextBlock Grid.Column="0" x:Name="lblLck" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" x:Name="numLck" Minimum="0" Maximum="99" Width="110" />
                    <CheckBox Grid.Column="2" x:Name="chkLckTonic" />
                    <CheckBox Grid.Column="3" x:Name="chkLckStatus" />
                    <CheckBox Grid.Column="4" x:Name="chkLckMeal" />
                </Grid>
                <!-- Def row -->
                <Grid ColumnDefinitions="80,90,60,60,60">
                    <TextBlock Grid.Column="0" x:Name="lblDef" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" x:Name="numDef" Minimum="0" Maximum="99" Width="110" />
                    <CheckBox Grid.Column="2" x:Name="chkDefTonic" />
                    <CheckBox Grid.Column="3" x:Name="chkDefStatus" />
                    <CheckBox Grid.Column="4" x:Name="chkDefMeal" />
                </Grid>
                <!-- Res row -->
                <Grid ColumnDefinitions="80,90,60,60,60">
                    <TextBlock Grid.Column="0" x:Name="lblRes" VerticalAlignment="Center" />
                    <NumericUpDown Grid.Column="1" x:Name="numRes" Minimum="0" Maximum="99" Width="110" />
                    <CheckBox Grid.Column="2" x:Name="chkResTonic" />
                    <CheckBox Grid.Column="3" x:Name="chkResStatus" />
                    <CheckBox Grid.Column="4" x:Name="chkResMeal" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button x:Name="btnMax" Content="Max Stats" Click="BtnMax_Click" />
            <Button x:Name="btnAllBonuses" Content="All Bonuses" Click="BtnAllBonuses_Click" />
            <Button x:Name="btnSave" Content="Save" Click="BtnSave_Click" />
            <Button x:Name="btnCancel" Content="Cancel" Click="BtnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>
