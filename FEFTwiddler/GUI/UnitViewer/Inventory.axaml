<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEFTwiddler.GUI.UnitViewer.Inventory">
    <StackPanel Spacing="4">
        <Grid ColumnDefinitions="32,180,70,110,110,80">
            <TextBlock Grid.Column="0" Text="" />
            <TextBlock Grid.Column="1" Text="Item" FontWeight="Bold" />
            <TextBlock Grid.Column="2" Text="Equipped" FontWeight="Bold" />
            <TextBlock Grid.Column="3" Text="+Forges" FontWeight="Bold" />
            <TextBlock Grid.Column="4" Text="Uses" FontWeight="Bold" />
            <TextBlock Grid.Column="5" Text="Hex" FontWeight="Bold" />
        </Grid>
        <!-- Slot 1 -->
        <Grid ColumnDefinitions="32,180,70,110,110,80">
            <Image x:Name="ItemPic_1" Grid.Column="0" Width="24" Height="24" />
            <ComboBox x:Name="ItemNameBox_1" Grid.Column="1" DisplayMemberBinding="{Binding DisplayName}" />
            <CheckBox x:Name="ItemIsEquipped_1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <NumericUpDown x:Name="ItemForgesBox_1" Grid.Column="3" Minimum="0" Maximum="7" />
            <NumericUpDown x:Name="ItemQuantBox_1" Grid.Column="4" Minimum="1" Maximum="35" />
            <TextBox x:Name="ItemHexBox_1" Grid.Column="5" MaxLength="8" />
        </Grid>
        <!-- Slot 2 -->
        <Grid ColumnDefinitions="32,180,70,110,110,80">
            <Image x:Name="ItemPic_2" Grid.Column="0" Width="24" Height="24" />
            <ComboBox x:Name="ItemNameBox_2" Grid.Column="1" DisplayMemberBinding="{Binding DisplayName}" />
            <CheckBox x:Name="ItemIsEquipped_2" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <NumericUpDown x:Name="ItemForgesBox_2" Grid.Column="3" Minimum="0" Maximum="7" />
            <NumericUpDown x:Name="ItemQuantBox_2" Grid.Column="4" Minimum="1" Maximum="35" />
            <TextBox x:Name="ItemHexBox_2" Grid.Column="5" MaxLength="8" />
        </Grid>
        <!-- Slot 3 -->
        <Grid ColumnDefinitions="32,180,70,110,110,80">
            <Image x:Name="ItemPic_3" Grid.Column="0" Width="24" Height="24" />
            <ComboBox x:Name="ItemNameBox_3" Grid.Column="1" DisplayMemberBinding="{Binding DisplayName}" />
            <CheckBox x:Name="ItemIsEquipped_3" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <NumericUpDown x:Name="ItemForgesBox_3" Grid.Column="3" Minimum="0" Maximum="7" />
            <NumericUpDown x:Name="ItemQuantBox_3" Grid.Column="4" Minimum="1" Maximum="35" />
            <TextBox x:Name="ItemHexBox_3" Grid.Column="5" MaxLength="8" />
        </Grid>
        <!-- Slot 4 -->
        <Grid ColumnDefinitions="32,180,70,110,110,80">
            <Image x:Name="ItemPic_4" Grid.Column="0" Width="24" Height="24" />
            <ComboBox x:Name="ItemNameBox_4" Grid.Column="1" DisplayMemberBinding="{Binding DisplayName}" />
            <CheckBox x:Name="ItemIsEquipped_4" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <NumericUpDown x:Name="ItemForgesBox_4" Grid.Column="3" Minimum="0" Maximum="7" />
            <NumericUpDown x:Name="ItemQuantBox_4" Grid.Column="4" Minimum="1" Maximum="35" />
            <TextBox x:Name="ItemHexBox_4" Grid.Column="5" MaxLength="8" />
        </Grid>
        <!-- Slot 5 -->
        <Grid ColumnDefinitions="32,180,70,110,110,80">
            <Image x:Name="ItemPic_5" Grid.Column="0" Width="24" Height="24" />
            <ComboBox x:Name="ItemNameBox_5" Grid.Column="1" DisplayMemberBinding="{Binding DisplayName}" />
            <CheckBox x:Name="ItemIsEquipped_5" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <NumericUpDown x:Name="ItemForgesBox_5" Grid.Column="3" Minimum="0" Maximum="7" />
            <NumericUpDown x:Name="ItemQuantBox_5" Grid.Column="4" Minimum="1" Maximum="35" />
            <TextBox x:Name="ItemHexBox_5" Grid.Column="5" MaxLength="8" />
        </Grid>
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="btnMaxForges" Content="Max Forges" Click="BtnMaxForges_Click" />
            <Button x:Name="btnMaxCharges" Content="Max Charges" Click="BtnMaxCharges_Click" />
        </StackPanel>
    </StackPanel>
</UserControl>
