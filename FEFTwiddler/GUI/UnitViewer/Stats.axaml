<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEFTwiddler.GUI.UnitViewer.Stats">
    <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock x:Name="lblStats" Text="Stats:" VerticalAlignment="Center" />
        <TextBlock x:Name="txtStatBytes" VerticalAlignment="Center" />
        <Button x:Name="btnStats" Content="Edit..." Click="BtnStats_Click" />
    </StackPanel>
</UserControl>
