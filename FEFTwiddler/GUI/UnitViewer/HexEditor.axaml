<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FEFTwiddler.GUI.Controls"
        x:Class="FEFTwiddler.GUI.UnitViewer.HexEditor"
        Width="600" Height="600"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="*,Auto" Margin="8">
        <ScrollViewer Grid.Row="0">
            <StackPanel Spacing="8">
                <TextBlock Text="Raw Block 1" FontWeight="Bold" />
                <controls:HexBox x:Name="hexRawBlock1" />

                <TextBlock Text="Raw Inventory" FontWeight="Bold" />
                <controls:HexBox x:Name="hexRawInventory" />

                <TextBlock Text="Raw Supports" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="lblRawNumberOfSupports" VerticalAlignment="Center" />
                    <controls:HexBox x:Name="hexRawSupports" />
                </StackPanel>

                <TextBlock Text="Raw Block 2" FontWeight="Bold" />
                <controls:HexBox x:Name="hexRawBlock2" />

                <TextBlock Text="Raw Learned Skills" FontWeight="Bold" />
                <controls:HexBox x:Name="hexRawLearnedSkills" />

                <TextBlock Text="Raw Deployed Unit Info" FontWeight="Bold" />
                <controls:HexBox x:Name="hexRawDeployedUnitInfo" />

                <TextBlock Text="Raw Block 3" FontWeight="Bold" />
                <controls:HexBox x:Name="hexRawBlock3" />

                <TextBlock Text="Raw End Block" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="lblRawEndBlockType" VerticalAlignment="Center" />
                    <controls:HexBox x:Name="hexRawEndBlock" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,8,0,0">
            <Button x:Name="btnSave" Content="Save" Click="BtnSave_Click" MinWidth="75" />
            <Button x:Name="btnCancel" Content="Cancel" Click="BtnCancel_Click" MinWidth="75" />
        </StackPanel>
    </Grid>
</Window>
