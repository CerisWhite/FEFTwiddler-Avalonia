<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEFTwiddler.GUI.UnitViewer.SupportPanel">
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,2">
        <TextBlock x:Name="lblName" Width="160" VerticalAlignment="Center" />
        <ComboBox x:Name="cmbSupport" Width="160" />
    </StackPanel>
</UserControl>
