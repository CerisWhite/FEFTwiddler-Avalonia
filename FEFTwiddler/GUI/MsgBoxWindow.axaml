<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="FEFTwiddler.GUI.MsgBoxWindow"
        Title="FEFTwiddler"
        Width="400" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="*,Auto" Margin="16">
        <TextBlock x:Name="lblMessage" Grid.Row="0"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" />
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="btnYes" Content="Yes" MinWidth="75" Click="BtnYes_Click" />
            <Button x:Name="btnNo" Content="No" MinWidth="75" Click="BtnNo_Click" />
            <Button x:Name="btnOk" Content="OK" MinWidth="75" Click="BtnOk_Click" />
        </StackPanel>
    </Grid>
</Window>
