<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEFTwiddler.GUI.Convoy.ConvoyItemPanel">
    <Grid ColumnDefinitions="32,200,24,110,Auto,110" Margin="0,2,0,2">
        <Image x:Name="picIcon" Grid.Column="0" Width="24" Height="24" />
        <TextBlock x:Name="lblName" Grid.Column="1" VerticalAlignment="Center" Margin="4,0" />
        <TextBlock x:Name="lblPlus" Grid.Column="2" VerticalAlignment="Center" />
        <NumericUpDown x:Name="numCharges" Grid.Column="3" Minimum="0" Maximum="255" />
        <TextBlock x:Name="lblMaxCharges" Grid.Column="4" VerticalAlignment="Center" Margin="2,0" />
        <NumericUpDown x:Name="numQuantity" Grid.Column="5" Minimum="0" Maximum="255" />
    </Grid>
</UserControl>
