<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FEFTwiddler.GUI.Controls.ColorPicker">
    <StackPanel Orientation="Horizontal" Spacing="4">
        <Border x:Name="pnlPreview" Width="24" Height="24" BorderThickness="1" BorderBrush="Gray"
                Background="White" Cursor="Hand" />
        <TextBox x:Name="txtHex" Width="64" MaxLength="6" />
    </StackPanel>
</UserControl>
